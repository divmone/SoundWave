<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.24.xsd">

    <!-- =================================================================== -->
    <!-- ChangeSet 1: Создание таблицы users (Пользователи)                 -->
    <!-- =================================================================== -->
    <changeSet id="1" author="soundwave">
        <createTable tableName="users">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="password_hash" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="display_name" type="varchar(255)"/>
            <column name="avatar_url" type="varchar(500)"/>
            <column name="role" type="varchar(20)" defaultValue="buyer">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        
        <rollback>
            <dropTable tableName="users"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 2: Создание таблицы seller_profiles (Профили продавцов)  -->
    <!-- =================================================================== -->
    <changeSet id="2" author="soundwave">
        <createTable tableName="seller_profiles">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false" unique="true" 
                           foreignKeyName="fk_seller_profiles_user" 
                           references="users(id)"/>
            </column>
            <column name="bio" type="text"/>
            <column name="website" type="varchar(255)"/>
            <column name="payout_info" type="text"/>
            <column name="total_sales" type="decimal(10,2)" defaultValue="0"/>
            <column name="rating" type="decimal(3,2)" defaultValue="0"/>
            <column name="verified_at" type="timestamp"/>
        </createTable>
        
        <rollback>
            <dropTable tableName="seller_profiles"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 3: Создание таблицы categories (Категории)                -->
    <!-- =================================================================== -->
    <changeSet id="3" author="soundwave">
        <createTable tableName="categories">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="slug" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="parent_id" type="bigint"/>
            <column name="description" type="text"/>
        </createTable>
        
        <addForeignKeyConstraint 
            constraintName="fk_categories_parent"
            baseTableName="categories" 
            baseColumnNames="parent_id"
            referencedTableName="categories" 
            referencedColumnNames="id"/>
        
        <rollback>
            <dropTable tableName="categories"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 4: Создание таблицы tags (Теги)                           -->
    <!-- =================================================================== -->
    <changeSet id="4" author="soundwave">
        <createTable tableName="tags">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="slug" type="varchar(100)">
                <constraints nullable="false" unique="true"/>
            </column>
        </createTable>
        
        <rollback>
            <dropTable tableName="tags"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 5: Создание таблицы sounds (Звуки/товары)                 -->
    <!-- =================================================================== -->
    <changeSet id="5" author="soundwave">
        <createTable tableName="sounds">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="seller_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_sounds_seller" 
                           references="seller_profiles(id)"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="price" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="preview_url" type="varchar(500)"/>
            <column name="file_url" type="varchar(500)">
                <constraints nullable="false"/>
            </column>
            <column name="duration_seconds" type="int"/>
            <column name="bpm" type="int"/>
            <column name="key" type="varchar(10)"/>
            <column name="file_format" type="varchar(10)"/>
            <column name="file_size_kb" type="int"/>
            <column name="status" type="varchar(20)" defaultValue="draft">
                <constraints nullable="false"/>
            </column>
            <column name="plays_count" type="int" defaultValue="0"/>
            <column name="downloads_count" type="int" defaultValue="0"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="updated_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
        
        <createIndex indexName="idx_sounds_seller" tableName="sounds">
            <column name="seller_id"/>
        </createIndex>
        
        <createIndex indexName="idx_sounds_status" tableName="sounds">
            <column name="status"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="sounds"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 6: Таблицы связей звуков с категориями и тегами           -->
    <!-- =================================================================== -->
    <changeSet id="6" author="soundwave">
        <!-- sound_categories -->
        <createTable tableName="sound_categories">
            <column name="sound_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_sound_categories_sound" 
                           references="sounds(id)"/>
            </column>
            <column name="category_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_sound_categories_category" 
                           references="categories(id)"/>
            </column>
        </createTable>
        
        <addPrimaryKey constraintName="pk_sound_categories" 
                      tableName="sound_categories" 
                      columnNames="sound_id, category_id"/>
        
        <!-- sound_tags -->
        <createTable tableName="sound_tags">
            <column name="sound_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_sound_tags_sound" 
                           references="sounds(id)"/>
            </column>
            <column name="tag_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_sound_tags_tag" 
                           references="tags(id)"/>
            </column>
        </createTable>
        
        <addPrimaryKey constraintName="pk_sound_tags" 
                      tableName="sound_tags" 
                      columnNames="sound_id, tag_id"/>
        
        <rollback>
            <dropTable tableName="sound_categories"/>
            <dropTable tableName="sound_tags"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 7: Создание таблицы sound_licenses (Лицензии на звуки)    -->
    <!-- =================================================================== -->
    <changeSet id="7" author="soundwave">
        <createTable tableName="sound_licenses">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sound_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_licenses_sound" 
                           references="sounds(id)"/>
            </column>
            <column name="license_type" type="varchar(20)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="allowed_uses" type="text"/>
        </createTable>
        
        <addUniqueConstraint constraintName="uk_sound_license_type" 
                            tableName="sound_licenses" 
                            columnNames="sound_id, license_type"/>
        
        <rollback>
            <dropTable tableName="sound_licenses"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 8: Создание таблиц для подборок (collections)             -->
    <!-- =================================================================== -->
    <changeSet id="8" author="soundwave">
        <createTable tableName="collections">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="seller_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_collections_seller" 
                           references="seller_profiles(id)"/>
            </column>
            <column name="title" type="varchar(255)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="text"/>
            <column name="cover_url" type="varchar(500)"/>
            <column name="is_public" type="boolean" defaultValueBoolean="true"/>
        </createTable>
        
        <createTable tableName="collection_sounds">
            <column name="collection_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_collection_sounds_collection" 
                           references="collections(id)"/>
            </column>
            <column name="sound_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_collection_sounds_sound" 
                           references="sounds(id)"/>
            </column>
            <column name="position" type="int" defaultValue="0"/>
        </createTable>
        
        <addPrimaryKey constraintName="pk_collection_sounds" 
                      tableName="collection_sounds" 
                      columnNames="collection_id, sound_id"/>
        
        <rollback>
            <dropTable tableName="collection_sounds"/>
            <dropTable tableName="collections"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 9: Создание таблиц для заказов (orders)                   -->
    <!-- =================================================================== -->
    <changeSet id="9" author="soundwave">
        <createTable tableName="orders">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="buyer_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_orders_buyer" 
                           references="users(id)"/>
            </column>
            <column name="total_amount" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(20)" defaultValue="pending">
                <constraints nullable="false"/>
            </column>
            <column name="payment_method" type="varchar(50)"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createTable tableName="order_items">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_order_items_order" 
                           references="orders(id)"/>
            </column>
            <column name="sound_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_order_items_sound" 
                           references="sounds(id)"/>
            </column>
            <column name="license_id" type="bigint">
                <constraints foreignKeyName="fk_order_items_license" 
                           references="sound_licenses(id)"/>
            </column>
            <column name="price_at_purchase" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="seller_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_order_items_seller" 
                           references="seller_profiles(id)"/>
            </column>
        </createTable>
        
        <rollback>
            <dropTable tableName="order_items"/>
            <dropTable tableName="orders"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 10: Создание таблицы downloads (Скачивания)               -->
    <!-- =================================================================== -->
    <changeSet id="10" author="soundwave">
        <createTable tableName="downloads">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_item_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_downloads_order_item" 
                           references="order_items(id)"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_downloads_user" 
                           references="users(id)"/>
            </column>
            <column name="downloaded_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="ip_address" type="varchar(45)"/>
        </createTable>
        
        <rollback>
            <dropTable tableName="downloads"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 11: Создание таблицы payouts (Выплаты продавцам)          -->
    <!-- =================================================================== -->
    <changeSet id="11" author="soundwave">
        <createTable tableName="payouts">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="seller_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_payouts_seller" 
                           references="seller_profiles(id)"/>
            </column>
            <column name="amount" type="decimal(10,2)">
                <constraints nullable="false"/>
            </column>
            <column name="commission_rate" type="decimal(5,2)" defaultValue="10.00"/>
            <column name="status" type="varchar(20)" defaultValue="pending"/>
            <column name="paid_at" type="timestamp"/>
        </createTable>
        
        <rollback>
            <dropTable tableName="payouts"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 12: Таблицы взаимодействий (reviews, wishlists, follows)  -->
    <!-- =================================================================== -->
    <changeSet id="12" author="soundwave">
        <!-- reviews -->
        <createTable tableName="reviews">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="sound_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_reviews_sound" 
                           references="sounds(id)"/>
            </column>
            <column name="buyer_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_reviews_buyer" 
                           references="users(id)"/>
            </column>
            <column name="rating" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="comment" type="text"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <addUniqueConstraint constraintName="uk_review_user_sound" 
                            tableName="reviews" 
                            columnNames="sound_id, buyer_id"/>
        
        <!-- wishlists -->
        <createTable tableName="wishlists">
            <column name="user_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_wishlists_user" 
                           references="users(id)"/>
            </column>
            <column name="sound_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_wishlists_sound" 
                           references="sounds(id)"/>
            </column>
            <column name="added_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <addPrimaryKey constraintName="pk_wishlists" 
                      tableName="wishlists" 
                      columnNames="user_id, sound_id"/>
        
        <!-- follows -->
        <createTable tableName="follows">
            <column name="follower_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_follows_follower" 
                           references="users(id)"/>
            </column>
            <column name="seller_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_follows_seller" 
                           references="seller_profiles(id)"/>
            </column>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <addPrimaryKey constraintName="pk_follows" 
                      tableName="follows" 
                      columnNames="follower_id, seller_id"/>
        
        <rollback>
            <dropTable tableName="reviews"/>
            <dropTable tableName="wishlists"/>
            <dropTable tableName="follows"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 13: Вспомогательные таблицы (notifications, promo_codes)  -->
    <!-- =================================================================== -->
    <changeSet id="13" author="soundwave">
        <!-- notifications -->
        <createTable tableName="notifications">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints nullable="false" 
                           foreignKeyName="fk_notifications_user" 
                           references="users(id)"/>
            </column>
            <column name="type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="payload" type="jsonb"/>
            <column name="is_read" type="boolean" defaultValueBoolean="false"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <!-- promo_codes -->
        <createTable tableName="promo_codes">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="code" type="varchar(50)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="discount_percent" type="int">
                <constraints nullable="false"/>
            </column>
            <column name="max_uses" type="int"/>
            <column name="used_count" type="int" defaultValue="0"/>
            <column name="expires_at" type="timestamp"/>
        </createTable>
        
        <rollback>
            <dropTable tableName="notifications"/>
            <dropTable tableName="promo_codes"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 14: Создание таблицы audit_logs (Лог действий)            -->
    <!-- =================================================================== -->
    <changeSet id="14" author="soundwave">
        <createTable tableName="audit_logs">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="bigint">
                <constraints foreignKeyName="fk_audit_logs_user" 
                           references="users(id)"/>
            </column>
            <column name="action" type="varchar(100)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_type" type="varchar(50)">
                <constraints nullable="false"/>
            </column>
            <column name="entity_id" type="bigint"/>
            <column name="created_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
        </createTable>
        
        <createIndex indexName="idx_audit_logs_user" tableName="audit_logs">
            <column name="user_id"/>
        </createIndex>
        
        <createIndex indexName="idx_audit_logs_entity" tableName="audit_logs">
            <column name="entity_type"/>
            <column name="entity_id"/>
        </createIndex>
        
        <rollback>
            <dropTable tableName="audit_logs"/>
        </rollback>
    </changeSet>

    <!-- =================================================================== -->
    <!-- ChangeSet 15: Индексы для производительности                        -->
    <!-- =================================================================== -->
    <changeSet id="15" author="soundwave">
        <!-- Индексы для поиска по звукам -->
        <createIndex indexName="idx_sounds_price" tableName="sounds">
            <column name="price"/>
        </createIndex>
        
        <createIndex indexName="idx_sounds_created" tableName="sounds">
            <column name="created_at"/>
        </createIndex>
        
        <createIndex indexName="idx_sounds_bpm" tableName="sounds">
            <column name="bpm"/>
        </createIndex>
        
        <!-- Индексы для заказов -->
        <createIndex indexName="idx_orders_buyer_status" tableName="orders">
            <column name="buyer_id"/>
            <column name="status"/>
        </createIndex>
        
        <createIndex indexName="idx_orders_created" tableName="orders">
            <column name="created_at"/>
        </createIndex>
        
        <!-- Индексы для поиска по тегам и категориям -->
        <createIndex indexName="idx_tags_name" tableName="tags">
            <column name="name"/>
        </createIndex>
        
        <createIndex indexName="idx_categories_slug" tableName="categories">
            <column name="slug"/>
        </createIndex>
        
        <rollback>
            <dropIndex indexName="idx_sounds_price" tableName="sounds"/>
            <dropIndex indexName="idx_sounds_created" tableName="sounds"/>
            <dropIndex indexName="idx_sounds_bpm" tableName="sounds"/>
            <dropIndex indexName="idx_orders_buyer_status" tableName="orders"/>
            <dropIndex indexName="idx_orders_created" tableName="orders"/>
            <dropIndex indexName="idx_tags_name" tableName="tags"/>
            <dropIndex indexName="idx_categories_slug" tableName="categories"/>
        </rollback>
    </changeSet>

</databaseChangeLog>