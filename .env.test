ENVIRONMENT=test

# для всех БД побудет так (комменты не вайбкод да)
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword

# для sounds
SOUNDS_DB_NAME=soundwaveSounds
STORAGE_PATH=/data/sounds
                          # ВАЖНО
OAUTH_TOKEN_CHECK_ENABLED=false
SOUNDS_LOG_LEVEL=info

# для auth
AUTH_DB_NAME=soundwaveUsers
AUTH_CPU_LIMIT=4
AUTH_LOG_LEVEL=info