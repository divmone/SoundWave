{
    "listeners": [
        {
            "address": "0.0.0.0",
            "port": 8080,
            "https": false
        }
    ],
    "app": {
        "threads_num": 4,
        "document_root": "http",
        "implicit_page": "index.html",
        "client_max_body_size": "100M"
    },
    "middlewares": [
      {
        "name": "soundwaveSounds::JWTAuthCheckMiddleware"
      }
    ],
    "db_clients": [
        {
            "name": "default",
            "rdbms": "postgresql",
            "host": "sounds-postgres",
            "port": 5432,
            "dbname": "soundwaveSounds",
            "user": "myuser",
            "passwd": "mypassword",
            "is_fast": false,
            "connection_number": 1,
            "auto_batch": false
        }
    ]
}
