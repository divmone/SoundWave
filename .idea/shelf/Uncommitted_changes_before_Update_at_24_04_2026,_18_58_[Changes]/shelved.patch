<+>server {\n    listen 80;\n    server_name soundwave.divmone.ru;\n\n    client_max_body_size 100M;\n\n    resolver 127.0.0.11 valid=30s;\n    set $auth_service    http://auth-service:8080;\n    set $sounds_service  http://sounds-service:8080;\n\n    root /usr/share/nginx/html;\n    index index.html;\n\n    location = /auth/google {\n        proxy_pass         $auth_service;\n        proxy_http_version 1.1;\n        proxy_set_header   Host              $host;\n        proxy_set_header   X-Real-IP         $remote_addr;\n        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;\n        proxy_set_header   X-Forwarded-Proto $http_x_forwarded_proto;\n    }\n\n    location = /auth/logout {\n        proxy_pass         $auth_service;\n        proxy_http_version 1.1;\n        proxy_set_header   Host              $host;\n        proxy_set_header   X-Real-IP         $remote_addr;\n        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;\n        proxy_set_header   X-Forwarded-Proto $http_x_forwarded_proto;\n    }\n\n    location = /auth/me {\n        proxy_pass         $auth_service;\n        proxy_http_version 1.1;\n        proxy_set_header   Host              $host;\n        proxy_set_header   X-Real-IP         $remote_addr;\n        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;\n        proxy_set_header   X-Forwarded-Proto $http_x_forwarded_proto;\n    }\n\n    location /auth/users/ {\n        proxy_pass         $auth_service;\n        proxy_http_version 1.1;\n        proxy_set_header   Host              $host;\n        proxy_set_header   X-Real-IP         $remote_addr;\n        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;\n        proxy_set_header   X-Forwarded-Proto $http_x_forwarded_proto;\n    }\n\n    location /users/ {\n        proxy_pass         $auth_service;\n        proxy_http_version 1.1;\n        proxy_set_header   Host              $host;\n        proxy_set_header   X-Real-IP         $remote_addr;\n        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;\n        proxy_set_header   X-Forwarded-Proto $http_x_forwarded_proto;\n    }\n\n    location /api/ {\n        proxy_pass         $sounds_service;\n        proxy_http_version 1.1;\n        proxy_set_header   Host              $host;\n        proxy_set_header   X-Real-IP         $remote_addr;\n        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;\n        proxy_set_header   X-Forwarded-Proto $http_x_forwarded_proto;\n        client_max_body_size 100M;\n\n        # Убираем upstream CORS-заголовки чтобы не было дублей (Safari блокирует \"*, *\")\n        proxy_hide_header Access-Control-Allow-Origin;\n        proxy_hide_header Access-Control-Allow-Methods;\n        proxy_hide_header Access-Control-Allow-Headers;\n\n        add_header Access-Control-Allow-Origin  * always;\n        add_header Access-Control-Allow-Methods \"GET, OPTIONS\" always;\n        add_header Access-Control-Allow-Headers \"Range, Authorization\" always;\n\n        if ($request_method = OPTIONS) {\n            return 204;\n        }\n    }\n\n    location / {\n        try_files $uri $uri/ /index.html;\n    }\n}\n\n# PgAdmin — отдельный server блок\nserver {\n    listen 80;\n    server_name pgadmin.divmone.ru;\n\n    location / {\n        proxy_pass http://pgadmin:80;\n        proxy_set_header Host $host;\n        proxy_set_header X-Real-IP $remote_addr;\n        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;\n        proxy_set_header X-Forwarded-Proto $scheme;\n    }\n}\n
